# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aveo?schema=public"

# Redis (for BullMQ job queues)
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="your-jwt-secret-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-change-this"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_AGENCY_PRICE_ID="price_..."

# Anthropic (Claude) for AI content generation
ANTHROPIC_API_KEY="sk-ant-..."

# FAL.ai for image generation (Flux model)
FAL_API_KEY="fal_..."

# ElevenLabs for voice synthesis
ELEVENLABS_API_KEY="el_..."

# HeyGen for video generation
HEYGEN_API_KEY="hg_..."

# AWS S3 for file storage
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="aveo-platform"
AWS_REGION="us-east-1"

# Resend for transactional emails
RESEND_API_KEY="re_..."

# App URLs
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
PORT=4000
NODE_ENV="development"
